# Copy this file to .env.local and fill only the providers you use.

# Chat/rewrite generation
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# OpenRouter-compatible chat and embeddings
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_EMBEDDINGS_URL=https://openrouter.ai/api/v1/embeddings
OPENROUTER_HTTP_REFERER=http://localhost/historycafe
OPENROUTER_TITLE=HistoryCafe

